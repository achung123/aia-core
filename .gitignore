.vscode/
.idea/
__pycache__/

# Dolt database files (added by bd init)
.dolt/
*.db

# Training data (large, not tracked in git)
data/
backend/data/

# Uploaded images (runtime artifacts)
uploads/
backend/uploads/

# YOLO training run outputs
runs/
backend/runs/

# Model weights — track only curated models, not raw training outputs
# (add specific model files with: git add -f backend/models/best_closeup.pt)
models/*
!models/.gitkeep
backend/models/*
!backend/models/.gitkeep

# Scratch files
yolo26n.pt
start.ps1
# Windows Zone.Identifier files
*:Zone.Identifier
